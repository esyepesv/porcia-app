# URL base del backend de PorcIA.
# Local: el backend expone las rutas en /register/*
#   VITE_API_BASE_URL=http://localhost:3000
# Producción: el backend vive en Vercel con prefijo /api
#   VITE_API_BASE_URL=https://porcia-backend.vercel.app/api
VITE_API_BASE_URL=http://localhost:3000

# PostHog (analytics). En local copia estos valores a .env.local.
# En producción (Vercel) configúralos en el dashboard del proyecto.
VITE_POSTHOG_PROJECT_TOKEN=
VITE_POSTHOG_HOST=https://us.i.posthog.com
